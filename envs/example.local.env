# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
APP_VERSION=v1.0.0
SECRET_KEY=CHANGE-ME-to-a-random-secret-key
COOKIE_DOMAIN=localhost
FRONTEND_BASE_URL=http://localhost:3000

# social login redirect URIs
KAKAO_REDIRECT_URI=http://localhost:8000/api/v1/auth/social/callback/kakao
KAKAO_LOGOUT_REDIRECT_URI=http://localhost:8000/api/v1/auth/social/logout/kakao
NAVER_REDIRECT_URI=http://localhost:8000/api/v1/auth/social/callback/naver
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/social/callback/google

# ai-worker
AI_WORKER_VERSION=v1.0.0

# openai
OPENAI_API_KEY=sk-proj-여기에-실제-키를-넣으세요
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# llm provider (openai | gemma_vllm)
LLM_PROVIDER=gemma_vllm
LLM_BASE_URL=http://gemma-runtime:8001/v1
LLM_MODEL=google/gemma-4-E4B-it
LLM_API_KEY=
LLM_FALLBACK_PROVIDER=openai
HF_TOKEN=
GEMMA_RUNTIME_PORT=8001
GEMMA_MAX_MODEL_LEN=4096
GEMMA_MAX_NUM_SEQS=1
GEMMA_MAX_NUM_BATCHED_TOKENS=2048
GEMMA_GPU_MEMORY_UTILIZATION=0.90

# youtube recommendations
YOUTUBE_API_KEY=
YOUTUBE_RECOMMENDATION_CACHE_TTL_SECONDS=43200
YOUTUBE_RECOMMENDATION_MAX_RESULTS=5

# web push notifications
WEB_PUSH_ENABLED=false
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY_B64=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com
WEB_PUSH_ACTION_API_BASE=

# db
DB_HOST=localhost
DB_PORT=5432
DB_EXPOSE_PORT=5432
DB_USER=ozcoding
DB_PASSWORD=pw1234
DB_ROOT_PASSWORD=Password123@!
DB_NAME=ai_health
DB_CONNECTION_POOL_MAXSIZE=10
DB_CONNECTION_POOL_MINSIZE=2

# redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=20

# email / smtp
MAIL_FROM=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SHARED_DEMO_PASSWORD=

# chat app context (off | help_only | live_state)
# 로컬에서는 실시간 상태(챌린지·리포트·미응답) 조회까지 활성화 권장
CHAT_APP_CONTEXT_MODE=live_state
