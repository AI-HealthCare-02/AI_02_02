# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
APP_VERSION=v1.0.0
SECRET_KEY=CHANGE-ME-to-a-random-secret-key
COOKIE_DOMAIN=localhost
FRONTEND_BASE_URL=https://your-domain.example

# social login redirect URIs
KAKAO_REDIRECT_URI=https://your-domain.example/api/v1/auth/social/callback/kakao
KAKAO_LOGOUT_REDIRECT_URI=https://your-domain.example/api/v1/auth/social/logout/kakao
NAVER_REDIRECT_URI=https://your-domain.example/api/v1/auth/social/callback/naver
GOOGLE_REDIRECT_URI=https://your-domain.example/api/v1/auth/social/callback/google

# ai-worker
AI_WORKER_VERSION=v1.0.0

# openai fallback
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# llm provider (openai | gemma_vllm)
LLM_PROVIDER=gemma_vllm
LLM_BASE_URL=http://gemma-runtime:8001/v1
LLM_MODEL=google/gemma-4-E4B-it
LLM_API_KEY=
LLM_FALLBACK_PROVIDER=openai
HF_TOKEN=
GEMMA_RUNTIME_PORT=8001
GEMMA_MAX_MODEL_LEN=4096
GEMMA_MAX_NUM_SEQS=1
GEMMA_MAX_NUM_BATCHED_TOKENS=2048
GEMMA_GPU_MEMORY_UTILIZATION=0.90

# db
DB_HOST=postgres
DB_PORT=5432
DB_EXPOSE_PORT=5432
DB_USER=ozcoding
DB_PASSWORD=Password1234@
DB_ROOT_PASSWORD=Ozcoding1234@
DB_NAME=ai_health

# db pool
DB_CONNECTION_POOL_MAXSIZE=25
DB_CONNECTION_POOL_MINSIZE=5

# redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# email / smtp
MAIL_FROM=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SHARED_DEMO_PASSWORD=

# chat app context (off | help_only | live_state)
# 프로덕션은 보수적으로 help_only 권장 (앱 UI 설명만, DB 조회 없음)
# 실시간 상태 조회까지 원하면 live_state, 개인정보·지연 영향 검토 후 활성화
CHAT_APP_CONTEXT_MODE=help_only
