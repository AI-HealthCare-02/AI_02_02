# docker
DOCKER_USER=ozcodingschool
DOCKER_REPOSITORY=ai-health

# fastapi
APP_VERSION=v1.0.0
SECRET_KEY=CHANGE-ME-to-a-random-secret-key
COOKIE_DOMAIN=localhost

# ai-worker
AI_WORKER_VERSION=v1.0.0

# db
DB_HOST=postgres
DB_PORT=5432
DB_EXPOSE_PORT=5432
DB_USER=ozcoding
DB_PASSWORD=Password1234@
DB_ROOT_PASSWORD=Ozcoding1234@
DB_NAME=ai_health

# db pool
DB_CONNECTION_POOL_MAXSIZE=25
