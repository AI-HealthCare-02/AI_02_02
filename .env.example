# docker
DOCKER_USER=your-docker-user
DOCKER_REPOSITORY=danaa-project

# fastapi
APP_VERSION=v1.0.0
SECRET_KEY=replace-with-a-secure-danaa-project-secret
COOKIE_DOMAIN=localhost

# ai-worker
AI_WORKER_VERSION=v1.0.0

# db
# 로컬 터미널/pytest/aerich 기준. docker compose 안의 fastapi/ai-worker는
# compose 파일에서 자동으로 DB_HOST=postgres 로 override 됩니다.
DB_HOST=localhost
DB_PORT=5432
DB_EXPOSE_PORT=5432
DB_USER=postgres
DB_PASSWORD=replace-with-db-password
DB_NAME=ai_health

# redis
REDIS_PORT=6379
