#!/bin/bash
set -eo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[0;33m'
NC='\033[0m'

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

echo -e "${BLUE}[pre-push] Running local checks before push...${NC}"

if command -v uv >/dev/null 2>&1; then
  RUFF_CMD=(uv run ruff)
  PYTEST_CMD=(uv run python -m pytest)
elif [ -x "$REPO_ROOT/.venv/Scripts/ruff.exe" ] && [ -x "$REPO_ROOT/.venv/Scripts/python.exe" ]; then
  RUFF_CMD=("$REPO_ROOT/.venv/Scripts/ruff.exe")
  PYTEST_CMD=("$REPO_ROOT/.venv/Scripts/python.exe" -m pytest)
elif [ -x "$REPO_ROOT/.venv/bin/ruff" ] && [ -x "$REPO_ROOT/.venv/bin/python" ]; then
  RUFF_CMD=("$REPO_ROOT/.venv/bin/ruff")
  PYTEST_CMD=("$REPO_ROOT/.venv/bin/python" -m pytest)
else
  echo -e "${RED}[pre-push] Could not find uv or repo virtualenv tools. Run 'uv sync --group app --group dev' first.${NC}"
  exit 1
fi

echo -e "${BLUE}[1/3] Backend lint${NC}"
"${RUFF_CMD[@]}" check backend

echo -e "${BLUE}[2/3] Backend unit tests${NC}"
"${PYTEST_CMD[@]}" backend/tests/unit -q

CHANGED_FRONTEND_FILES=$(git diff --cached --name-only -- frontend)

if [ -n "$CHANGED_FRONTEND_FILES" ]; then
  echo -e "${BLUE}[3/3] Frontend build${NC}"
  (
    cd frontend
    npm run build
  )
else
  echo -e "${YELLOW}[3/3] Frontend build skipped (no staged frontend changes).${NC}"
fi

echo -e "${GREEN}[pre-push] All checks passed. Push allowed.${NC}"
