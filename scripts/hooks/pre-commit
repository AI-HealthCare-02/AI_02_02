#!/bin/bash
# pre-commit hook: staged Python 파일에 ruff check 실행
# 에러 있으면 커밋 차단
set -eo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

# staged Python 파일 목록 (삭제된 파일 제외)
STAGED_PY_FILES=$(git diff --cached --name-only --diff-filter=d -- '*.py')

if [ -z "$STAGED_PY_FILES" ]; then
  exit 0
fi

echo -e "${BLUE}[pre-commit] staged Python 파일 ruff check 실행...${NC}"

# ruff 실행 경로 결정
REPO_ROOT=$(git rev-parse --show-toplevel)

if command -v uv &> /dev/null; then
  RUFF_CMD="uv run ruff"
elif [ -f "$REPO_ROOT/.venv/Scripts/ruff.exe" ]; then
  RUFF_CMD="$REPO_ROOT/.venv/Scripts/ruff"
elif [ -f "$REPO_ROOT/.venv/bin/ruff" ]; then
  RUFF_CMD="$REPO_ROOT/.venv/bin/ruff"
else
  echo -e "${RED}[pre-commit] ruff를 찾을 수 없습니다. 'uv sync' 를 실행해주세요.${NC}"
  exit 1
fi

# staged 파일만 ruff check (자동 수정 안 함)
FAILED=0
echo "$STAGED_PY_FILES" | tr '\n' '\0' | xargs -0 $RUFF_CMD check --no-fix || FAILED=1

if [ $FAILED -ne 0 ]; then
  echo ""
  echo -e "${RED}========================================${NC}"
  echo -e "${RED}  커밋 차단: ruff 린트 에러가 있습니다  ${NC}"
  echo -e "${RED}========================================${NC}"
  echo -e "${RED}  수정 후 다시 커밋해주세요.${NC}"
  echo -e "${RED}  자동 수정: uv run ruff check . --fix${NC}"
  exit 1
fi

echo -e "${GREEN}[pre-commit] ruff check 통과!${NC}"
exit 0
